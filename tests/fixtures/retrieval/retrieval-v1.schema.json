{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/event4u-app/agent-memory/tests/fixtures/retrieval/retrieval-v1.schema.json",
  "title": "Retrieval Contract v1",
  "description": "Shape-only cross-repo contract between agent-memory and consumers (e.g. agent-config). See agents/roadmaps/from-agent-config/road-to-retrieval-contract.md.",
  "type": "object",
  "required": ["contract_version", "status", "entries", "slices", "errors"],
  "additionalProperties": true,
  "properties": {
    "contract_version": {
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": ["ok", "partial", "error"]
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    },
    "slices": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/slice" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/error" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": ["id", "type", "source", "confidence", "body"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "enum": ["repo", "operational"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "trust": { "type": "number", "minimum": 0, "maximum": 1 },
        "body": { "type": "object" },
        "last_validated": { "type": "string", "format": "date-time" },
        "shadowed_by": { "type": ["string", "null"] }
      }
    },
    "slice": {
      "type": "object",
      "required": ["status", "count"],
      "additionalProperties": true,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "timeout", "unknown_type", "misconfigured", "internal"]
        },
        "count": { "type": "integer", "minimum": 0 },
        "message": { "type": "string" }
      }
    },
    "error": {
      "type": "object",
      "required": ["type", "code", "message"],
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "code": {
          "type": "string",
          "enum": ["ok", "timeout", "unknown_type", "misconfigured", "internal"]
        },
        "message": { "type": "string" }
      }
    }
  }
}
