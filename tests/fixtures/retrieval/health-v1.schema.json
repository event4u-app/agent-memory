{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/event4u-app/agent-memory/tests/fixtures/retrieval/health-v1.schema.json",
  "title": "Health Contract v1",
  "type": "object",
  "required": ["contract_version", "status", "backend_version", "features"],
  "additionalProperties": true,
  "properties": {
    "contract_version": { "const": 1 },
    "status": {
      "type": "string",
      "enum": ["ok", "degraded", "error"]
    },
    "backend_version": {
      "type": "string",
      "minLength": 1
    },
    "features": {
      "type": "array",
      "items": { "type": "string" }
    },
    "latency_ms": { "type": "number", "minimum": 0 },
    "counts": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    }
  }
}
