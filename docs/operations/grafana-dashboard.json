{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Scrapes agent-memory /metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Retrieve latency — P50 / P95 / P99 (5m)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.2 },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "refId": "P50",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(agent_memory_retrieve_duration_seconds_bucket[5m])))",
          "legendFormat": "P50"
        },
        {
          "refId": "P95",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_memory_retrieve_duration_seconds_bucket[5m])))",
          "legendFormat": "P95"
        },
        {
          "refId": "P99",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(agent_memory_retrieve_duration_seconds_bucket[5m])))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 2,
      "title": "DB pool saturation",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "refId": "A",
          "expr": "agent_memory_db_pool_saturation"
        }
      ]
    },
    {
      "id": 3,
      "title": "Embedding fallbacks (rate 5m)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "stacking": { "mode": "normal", "group": "A" } }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (from, to) (rate(agent_memory_embedding_fallback_total[5m]))",
          "legendFormat": "{{from}} → {{to}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Trust transitions (rate 5m)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "stacking": { "mode": "normal", "group": "A" } }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (from, to) (rate(agent_memory_trust_transitions_total[5m]))",
          "legendFormat": "{{from}} → {{to}}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["agent-memory", "runtime-trust"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "label": "Prometheus",
        "query": "prometheus",
        "refresh": 1
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "agent-memory — runtime SLO",
  "uid": "agent-memory-runtime-slo",
  "version": 1,
  "weekStart": ""
}
