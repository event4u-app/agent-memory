# Database
DATABASE_URL=postgresql://memory:memory_dev@localhost:5433/agent_memory
DATABASE_URL_TEST=postgresql://memory:memory_dev@localhost:5434/agent_memory_test

# Embedding Provider (auto-detected if not set)
# Options: local, gemini, openai, voyage, bm25-only
# EMBEDDING_PROVIDER=local

# API Keys (only needed if using external providers)
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# VOYAGE_API_KEY=

# Token Budget
MEMORY_TOKEN_BUDGET=2000

# Trust Thresholds
MEMORY_TRUST_THRESHOLD_DEFAULT=0.6
MEMORY_TRUST_THRESHOLD_LOW=0.3

# MCP Server
MCP_PORT=3100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
