# Team-memory deployment — environment.
#
# Copy to .env on the Hetzner host and fill in. Never commit the real
# .env. The two secret values live in the team's password vault.
#
# Decisions:
#   ADR-0004 — hosting (Hetzner CX22)
#   ADR-0005 — auth (Tailscale + bearer token)

# --- Required ---

# Postgres password. Generate with `openssl rand -hex 32`.
# Stored in the team vault under `team-memory/postgres`.
POSTGRES_PASSWORD=

# MCP bearer token. Generate with `openssl rand -hex 32`.
# Distributed to every developer via the team vault.
# Rotate quarterly by re-deploying with a fresh value (ADR-0005).
MEMORY_MCP_AUTH_TOKEN=

# Tailnet IPv4 address of THIS host (100.x.x.x).
# Get it with: tailscale ip -4
# The SSE listener binds to this address only — never to 0.0.0.0.
TAILNET_IP=

# --- Optional ---

# Image tag. Pin to a specific version in production for reproducibility.
# MEMORY_IMAGE_TAG=1.1.0
MEMORY_IMAGE_TAG=latest

# Log level (debug | info | warn | error). info is sufficient for
# steady state; raise to debug during the spike (Phase 2).
LOG_LEVEL=info
