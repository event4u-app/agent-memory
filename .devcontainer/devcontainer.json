{
	"name": "agent-memory (Node 20 + Postgres + pgvector)",
	"dockerComposeFile": [
		"../docker-compose.yml",
		"docker-compose.devcontainer.yml"
	],
	"service": "devcontainer",
	"workspaceFolder": "/workspace",
	"shutdownAction": "stopCompose",

	// Wait for Postgres to be healthy before the post-create hook runs
	// migrations. `depends_on` in docker-compose.devcontainer.yml wires
	// the healthcheck; this flag just forwards the signal to VS Code.
	"waitFor": "postCreateCommand",

	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": true,
			"configureZshAsDefaultShell": false,
			"upgradePackages": false
		},
		"ghcr.io/devcontainers/features/git:1": {}
	},

	"postCreateCommand": "bash .devcontainer/post-create.sh",

	"customizations": {
		"vscode": {
			"extensions": [
				"dbaeumer.vscode-eslint",
				"biomejs.biome",
				"esbenp.prettier-vscode",
				"ms-azuretools.vscode-docker",
				"mtxr.sqltools",
				"mtxr.sqltools-driver-pg"
			],
			"settings": {
				"editor.formatOnSave": true,
				"editor.defaultFormatter": "biomejs.biome",
				"typescript.tsdk": "node_modules/typescript/lib"
			}
		}
	},

	"remoteUser": "node",

	// Forward the dev Postgres so host-side tools (e.g. a local TablePlus
	// via the VS Code Remote tunnel) can connect without extra config.
	"forwardPorts": [5433]
}
