# Copy to .env and source it before `npm start`:
#   cp .env.example .env && export $(grep -v '^#' .env | xargs)

# Points at the postgres service from the monorepo docker-compose.yml.
# If you run Postgres elsewhere, update the URL.
DATABASE_URL=postgresql://memory:memory_dev@localhost:5433/agent_memory

# Required by file/symbol validators. Should be the absolute path to
# whatever repository these memory entries describe.
REPO_ROOT=/abs/path/to/your/project

# Default log level; set LOG_LEVEL=debug for verbose output.
LOG_LEVEL=info
