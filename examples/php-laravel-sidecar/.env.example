# Laravel app env — add these to your .env alongside APP_*, DB_*, etc.
# These are the only three values the PHP side needs to talk to the
# agent-memory sidecar. Everything else (DATABASE_URL, PGVECTOR config)
# stays inside the Docker network and is set in docker-compose.yml.

# Used by the CallMemory example action (app/Actions/CallMemory.php)
# to choose how to invoke the CLI. "docker" uses docker compose exec;
# "local" expects the `memory` binary on PATH.
AGENT_MEMORY_DRIVER=docker

# Compose service name of the agent-memory sidecar. Override if you
# renamed the service in docker-compose.yml.
AGENT_MEMORY_SERVICE=agent-memory

# Repository identifier sent with every propose/retrieve call. Ties
# memory entries to this app in multi-repo deployments.
AGENT_MEMORY_REPOSITORY=my-laravel-app
